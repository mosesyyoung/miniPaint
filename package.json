{
  "name": "miniPaint",
  "version": "4.14.3",
  "author": "Vilius L.",
  "description": "Online graphics editing tool lets create, edit images using HTML5 technologies.",
  "keywords": [
    "canvas",
    "drawing",
    "paint",
    "layers",
    "effects"
  ],
  "scripts": {
    "server": "webpack serve --mode development --env development --open",
    "dev": "webpack --mode development",
    "build": "webpack --mode production",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:integration": "playwright test tests/e2e/integration.spec.js",
    "test:visual": "playwright test tests/e2e/visual.spec.js",
    "test:io": "playwright test tests/e2e/import-export.spec.js",
    "test:cross-browser": "playwright test --config=playwright.cross-browser.config.js tests/e2e/cross-browser.spec.js",
    "test:security": "playwright test tests/e2e/security.spec.js",
    "test:performance": "playwright test tests/e2e/performance.spec.js",
    "test:a11y": "playwright test tests/e2e/accessibility.spec.js",
    "test:i18n": "playwright test tests/e2e/i18n.spec.js",
    "test:regression": "node scripts/regression-report.mjs",
    "test:regression:all": "node scripts/regression-report.mjs --all",
    "check:static-paths": "node scripts/check-static-paths.js",
    "fixtures:generate": "node tests/fixtures/generate-fixtures.mjs",
    "fixtures:validate": "node tests/fixtures/validate-fixtures.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/viliusle/miniPaint"
  },
  "homepage": "https://github.com/viliusle/miniPaint",
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@babel/core": "^7.14.5",
    "@babel/plugin-transform-runtime": "^7.14.5",
    "@babel/preset-env": "^7.14.5",
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^4.1.8",
    "babel-loader": "^8.2.2",
    "css-loader": "^5.2.6",
    "http-server": "^14.1.1",
    "jpeg-js": "^0.4.4",
    "jsdom": "^29.1.1",
    "omggif": "^1.0.10",
    "source-map-loader": "^3.0.0",
    "style-loader": "^2.0.0",
    "vitest": "^4.1.8",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "@babel/runtime": "^7.14.5",
    "alertifyjs": "^1.13.1",
    "blueimp-canvas-to-blob": "^3.28.0",
    "exif-js": "^2.3.0",
    "file-saver": "^2.0.5",
    "fuzzysort": "^1.1.4",
    "gif.js.optimized": "^1.0.1",
    "hermite-resize": "git+https://github.com/viliusle/Hermite-resize.git",
    "jquery": "^3.5.1",
    "pica": "^7.0.0",
    "semver-compare": "^1.0.0",
    "uuid": "^11.1.1",
    "webfontloader": "^1.6.28"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
